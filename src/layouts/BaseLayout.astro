---
// SPDX-License-Identifier: AGPL-3.0-or-later
// Copyright (C) 2026 MamaShip
//
// 共享布局：网站随时间长出更多工具，每个工具 = 一个新路由，复用此外壳。
// 内容页（首页/about）套「轻量顶栏 + 内容容器 + 页脚」骨架；占满视口的工具页
// （地图）传 fullBleed，直接铺满、不带顶栏/页脚（沉浸式）。
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";

interface Props {
  title: string;
  description?: string;
  /** 地图等需占满视口的工具页设为 true，去掉顶栏/页脚与内容边距 */
  fullBleed?: boolean;
  /** 内容页用更宽的容器（首页栅格用 wide，about 阅读列用窄） */
  wide?: boolean;
  /** 页签图标：默认皮靴品牌图标；老地图页传旧的青绿地图针 svg（更贴该页主题） */
  favicon?: string;
}

const {
  title,
  description,
  fullBleed = false,
  wide = false,
  favicon = "/portkey-icon.png",
} = Astro.props;
const siteName = "Portkey Tools";
const faviconType = favicon.endsWith(".svg") ? "image/svg+xml" : "image/png";
---

<!doctype html>
<html lang="zh">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href={favicon} type={faviconType} />
    {!fullBleed && <link rel="apple-touch-icon" href="/apple-touch-icon.png" />}
    {description && <meta name="description" content={description} />}
    <title>{title === siteName ? title : `${title} · ${siteName}`}</title>
  </head>
  <body class:list={[{ fullbleed: fullBleed, wide }]}>
    {
      fullBleed ? (
        <slot />
      ) : (
        <>
          <SiteHeader />
          <main class="container site-main">
            <slot />
          </main>
          <SiteFooter />
        </>
      )
    }
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light dark;
    /* —— 统一设计令牌：暖色系（呼应皮靴 logo），珊瑚暖橙主色保持年轻活泼。
       仅内容页（首页/about/顶栏/页脚）消费；地图页为自带中性白玻璃，不受影响 —— */
    --accent: #ec7a45;
    --accent-ink: #a8481a;
    --ink: #221c18;
    --muted: #7c6f66;
    --bg: #faf7f3;
    --card-bg: rgba(255, 255, 255, 0.92);
    --card-border: rgba(236, 122, 69, 0.16);
    --card-shadow: 0 1px 6px rgba(0, 0, 0, 0.08);
    --card-shadow-hover: 0 10px 30px rgba(236, 122, 69, 0.2);
    --radius: 12px;
    --content-narrow: 42rem;
    --content-wide: 62rem;
  }
  * {
    box-sizing: border-box;
  }
  html,
  body {
    margin: 0;
    padding: 0;
    height: 100%;
  }
  body {
    font-family:
      system-ui,
      -apple-system,
      "Segoe UI",
      "Noto Sans SC",
      sans-serif;
    line-height: 1.6;
    color: var(--ink);
  }
  /* 内容型页面（首页/about）：纵向骨架 + 极淡背景 */
  body:not(.fullbleed) {
    display: flex;
    flex-direction: column;
    min-height: 100%;
    background: var(--bg);
    /* 允许 hero 背景用 100vw 横向满铺而不触发横向滚动条；
       clip（非 hidden）不创建滚动容器，sticky 顶栏不受影响 */
    overflow-x: clip;
  }
  body:not(.fullbleed) .site-main {
    flex: 1;
  }
  /* 共享内容容器：左右收口 + 横向内边距；宽度按页面 narrow / wide 切换 */
  .container {
    width: 100%;
    max-width: var(--content-narrow);
    margin: 0 auto;
    padding-inline: 1.25rem;
  }
  body.wide .container {
    max-width: var(--content-wide);
  }
  .site-main {
    padding-block: 2.5rem 3.5rem;
  }
  /* 工具页（地图）占满视口，无边距 */
  body.fullbleed {
    overflow: hidden;
  }
  a {
    color: var(--accent-ink);
  }
</style>
