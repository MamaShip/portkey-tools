---
// SPDX-License-Identifier: AGPL-3.0-or-later
// Copyright (C) 2026 MamaShip
//
// 来源与版权页：构建期遍历 maps 登记表，逐图自动列出来源/收藏机构/制图者/许可，
// 不再手工维护（新增一张图即自动出现在此）。零运行时 JS。
import BaseLayout from "../layouts/BaseLayout.astro";
import { maps } from "../data/maps";

// 按年份升序展示（旧 → 新）。
const ordered = [...maps].sort((a, b) => a.year - b.year);
---

<BaseLayout
  title="来源与版权"
  description="历史地图来源、收藏机构与侵权举报入口。"
>
  <h1>来源与版权</h1>
  <p>
    本站历史地图均取自公共领域（制图者多为当时政府机构）。下方逐图列出来源、收藏机构、制图者与许可状态。
  </p>

  {
    ordered.map((m) => (
      <section style="margin:1.5rem 0;padding:1rem 1.1rem;border:1px solid rgba(128,128,128,0.25);border-radius:10px;">
        <h2 style="margin:0 0 0.5rem;font-size:1.05rem;">
          {m.title}
          <span style="font-weight:400;color:#888;">· {m.year}</span>
        </h2>
        <dl style="margin:0;display:grid;grid-template-columns:auto 1fr;gap:0.25rem 0.75rem;">
          <dt style="color:#888;">来源 / 收藏</dt>
          <dd style="margin:0;">{m.provenance.source}</dd>
          {m.provenance.author && (
            <>
              <dt style="color:#888;">制图者</dt>
              <dd style="margin:0;">{m.provenance.author}</dd>
            </>
          )}
          <dt style="color:#888;">许可</dt>
          <dd style="margin:0;">{m.provenance.license}</dd>
          {m.provenance.notes && (
            <>
              <dt style="color:#888;">备注</dt>
              <dd style="margin:0;">{m.provenance.notes}</dd>
            </>
          )}
        </dl>
      </section>
    ))
  }

  <p>现代底图 © OpenStreetMap 贡献者 / OpenFreeMap（地图角标自动署名）。</p>
  <p>
    配准标注（控制点）数据以 <strong>CC0</strong> 发布；站点代码以 AGPL-3.0-or-later
    授权。
  </p>

  <h2>侵权举报</h2>
  <p>
    若你认为某张图存在版权问题，请邮件联系
    <a href="mailto:youdangls@gmail.com">youdangls@gmail.com</a
    >，我会将对应图片下架。
  </p>
  <p><a href="/">← 返回首页</a></p>
</BaseLayout>
