import BaseLayout from "../layouts/BaseLayout.astro";

// 工具索引：网站随时间不断长出新工具，每个工具一条目。
const tools = [
  {
    href: "/cd-old-map",
    title: "成都老地图",
    desc: "在现代地图上叠加经过地理配准的成都历史老地图，可在时间轴上切换并淡入淡出对照。",
  },
];
---

<BaseLayout title="Portkey Tools" description="一个提供有趣小工具的个人网站。">
  <h1>Portkey Tools</h1>
  <p>一个提供有趣小工具的个人网站。</p>

  <h2>工具</h2>
  <ul>
    {
      tools.map((t) => (
        <li>
          <a href={t.href}>{t.title}</a>
          <span> — {t.desc}</span>
        </li>
      ))
    }
  </ul>

  <hr />
  <p>
    <a href="/about">关于</a>
  </p>
</BaseLayout>
