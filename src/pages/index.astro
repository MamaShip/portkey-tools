---
// SPDX-License-Identifier: AGPL-3.0-or-later
// Copyright (C) 2026 MamaShip
import BaseLayout from "../layouts/BaseLayout.astro";

const REPO_URL = "https://github.com/MamaShip/portkey-tools";

// 工具索引：网站随时间不断长出新工具，每个工具一条目。
// status: "live" 可点进工具页；"cta" 行动卡（虚线样式但可点击，跳外链，如提需求）；
//         "soon" 占位卡（暗示站点持续生长，不可点击）。
// external: true → 用新标签页打开（外部链接，如 GitHub）。
// icon: 内联 SVG 的 <path d> 列表，统一在 24×24 视框、currentColor 描边渲染。
type Tool = {
  href?: string;
  external?: boolean;
  title: string;
  desc: string;
  status: "live" | "cta" | "soon";
  paths: string[];
};

const tools: Tool[] = [
  {
    href: "/cd-old-map",
    title: "成都老地图",
    desc: "在现代地图上叠加经过锚点标定的成都历史老地图。可以切换不同时间节点，进行古今对照查看。",
    status: "live",
    paths: ["M9 4 3 7v13l6-3 6 3 6-3V4l-6 3-6-3z", "M9 4v13", "M15 7v13"],
  },
  {
    title: "更多工具",
    desc: "这里会持续长出新的小工具。敬请期待。",
    status: "soon",
    paths: ["M12 5v14", "M5 12h14"],
  },
  {
    href: `${REPO_URL}/issues/new?template=tool-request.yml`,
    external: true,
    title: "许愿池",
    desc: "有想法或建议？去 GitHub 上提一个 issue，一起决定下一个做什么。",
    status: "cta",
    paths: [
      "M9 18h6",
      "M10 22h4",
      "M12 2a7 7 0 0 0-4 12.7c.6.5 1 1.3 1 2.1V17h6v-.2c0-.8.4-1.6 1-2.1A7 7 0 0 0 12 2z",
    ],
  },
];
---

<BaseLayout
  title="门钥匙集散中心"
  description="批发门钥匙，带你去有趣的地方。"
  wide
>
  <section class="hero">
    <img
      class="hero-mark"
      src="/portkey-logo.webp"
      width="176"
      height="176"
      alt="Portkey Tools"
    />
    <h1 class="hero-title">门钥匙集散中心</h1>
    <p class="hero-tagline">批发门钥匙，带你去有趣的地方。</p>
  </section>

  <section aria-label="工具列表">
    <h2 class="section-title">工具</h2>
    <ul class="grid">
      {
        tools.map((t, i) => {
          const icon = (
            <svg
              class="card-icon"
              viewBox="0 0 24 24"
              width="26"
              height="26"
              aria-hidden="true"
            >
              {t.paths.map((d) => (
                <path
                  d={d}
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.8"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              ))}
            </svg>
          );
          const clickable = t.status === "live" || t.status === "cta";
          const body = (
            <>
              <span class="card-icon-wrap">{icon}</span>
              <span class="card-body">
                <span class="card-head">
                  <span class="card-title">{t.title}</span>
                  {t.status === "soon" && <span class="badge">敬请期待</span>}
                </span>
                <span class="card-desc">{t.desc}</span>
              </span>
              {clickable && (
                <span class="card-arrow" aria-hidden="true">
                  →
                </span>
              )}
            </>
          );
          return (
            <li class="reveal" style={`--d:${i * 80}ms`}>
              {clickable ? (
                <a
                  class={`card ${t.status === "live" ? "card-live" : "card-cta"}`}
                  href={t.href}
                  {...(t.external
                    ? { target: "_blank", rel: "noopener noreferrer" }
                    : {})}
                >
                  {body}
                </a>
              ) : (
                <div class="card card-soon" aria-disabled="true">
                  {body}
                </div>
              )}
            </li>
          );
        })
      }
    </ul>
  </section>
</BaseLayout>

<style>
  /* —— Hero —— */
  .hero {
    position: relative;
    text-align: center;
    padding: 2.5rem 0 3rem;
    isolation: isolate;
  }
  /* 暖褐/皮革径向渐变背景（取自皮靴色，呼应 logo），缓慢漂移。
     横向铺满整个视口（挣脱居中容器），左右无可见边界。 */
  .hero::before {
    content: "";
    position: absolute;
    top: -10%;
    bottom: 0;
    left: 50%;
    width: 100vw;
    transform: translateX(-50%);
    z-index: -1;
    background:
      radial-gradient(
        50% 70% at 22% 25%,
        rgba(168, 134, 98, 0.24),
        transparent 72%
      ),
      radial-gradient(
        55% 65% at 78% 30%,
        rgba(140, 98, 60, 0.18),
        transparent 72%
      );
    background-size: 160% 160%;
    animation: drift 18s ease-in-out infinite alternate;
  }
  .hero-mark {
    display: block;
    width: clamp(132px, 26vw, 192px);
    height: auto;
    margin: 0 auto 1rem;
    filter: drop-shadow(0 10px 18px rgba(0, 0, 0, 0.22));
    animation: float 5s ease-in-out infinite;
  }
  .hero-title {
    margin: 0;
    font-size: clamp(2rem, 6vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.5px;
    background: linear-gradient(120deg, var(--ink), var(--accent-ink));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .hero-tagline {
    margin: 0.6rem 0 0;
    color: var(--muted);
    font-size: 1.05rem;
  }

  /* —— 工具栅格 —— */
  .section-title {
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 0 0 1rem;
  }
  .grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 17rem), 1fr));
    gap: 1rem;
  }
  .card {
    display: flex;
    align-items: flex-start;
    gap: 0.9rem;
    height: 100%;
    padding: 1.15rem 1.2rem;
    border-radius: var(--radius);
    border: 1px solid var(--card-border);
    background: var(--card-bg);
    box-shadow: var(--card-shadow);
    text-decoration: none;
    color: inherit;
  }
  .card-live {
    transition:
      transform 0.22s ease,
      box-shadow 0.22s ease,
      border-color 0.22s ease;
  }
  .card-live:hover {
    transform: translateY(-4px);
    box-shadow: var(--card-shadow-hover);
    border-color: rgba(236, 122, 69, 0.35);
  }
  .card-soon {
    border-style: dashed;
    background: rgba(255, 255, 255, 0.55);
    box-shadow: none;
    cursor: default;
  }
  .card-soon .card-icon-wrap,
  .card-soon .card-title,
  .card-soon .card-desc {
    opacity: 0.65;
  }
  /* 行动卡：虚线边框暗示「未来 / 共建」，但可点击跳转（提需求） */
  .card-cta {
    border-style: dashed;
    box-shadow: none;
    transition:
      transform 0.22s ease,
      box-shadow 0.22s ease,
      border-color 0.22s ease;
  }
  .card-cta:hover {
    transform: translateY(-4px);
    box-shadow: var(--card-shadow-hover);
    border-color: rgba(236, 122, 69, 0.45);
  }
  .card-cta:hover .card-icon-wrap {
    background: rgba(236, 122, 69, 0.16);
  }
  .card-icon-wrap {
    flex: none;
    display: grid;
    place-items: center;
    width: 44px;
    height: 44px;
    border-radius: 11px;
    color: var(--accent);
    background: rgba(236, 122, 69, 0.1);
  }
  .card-live:hover .card-icon-wrap {
    background: rgba(236, 122, 69, 0.16);
  }
  .card-body {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    min-width: 0;
  }
  .card-head {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .card-title {
    font-weight: 700;
    font-size: 1.05rem;
  }
  .card-desc {
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.5;
  }
  .badge {
    flex: none;
    font-size: 0.68rem;
    font-weight: 600;
    padding: 0.1rem 0.45rem;
    border-radius: 999px;
    color: var(--accent-ink);
    background: rgba(236, 122, 69, 0.12);
  }
  .card-arrow {
    flex: none;
    align-self: center;
    color: var(--accent);
    font-size: 1.2rem;
    transition: transform 0.22s ease;
  }
  .card-live:hover .card-arrow,
  .card-cta:hover .card-arrow {
    transform: translateX(4px);
  }

  /* —— 入场动画：错落淡入上浮（纯 CSS，首屏内容零 JS） —— */
  .reveal {
    opacity: 0;
    animation: rise 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: var(--d, 0ms);
  }
  @keyframes rise {
    from {
      opacity: 0;
      transform: translateY(14px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }
  @keyframes float {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-7px);
    }
  }
  @keyframes drift {
    from {
      background-position: 0% 0%;
    }
    to {
      background-position: 100% 100%;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero::before,
    .hero-mark,
    .reveal {
      animation: none;
    }
    .reveal {
      opacity: 1;
    }
  }
</style>
