---
// SPDX-License-Identifier: AGPL-3.0-or-later
// Copyright (C) 2026 MamaShip
//
// 内容页共享顶栏（纯静态、零 JS）：左侧品牌（青绿地图针 Logo + 字标，链到首页），
// 右侧导航（首页 / 关于 / GitHub 外链）。当前页用 aria-current 高亮。
// 地图页为沉浸式不挂顶栏（见 BaseLayout fullBleed 分支）。
const REPO_URL = "https://github.com/MamaShip/portkey-tools";
const path = Astro.url.pathname.replace(/\/$/, "") || "/";
const isHome = path === "/";
const isAbout = path === "/about";
---

<header class="site-header">
  <div class="container bar">
    <a class="brand" href="/" aria-label="Portkey Tools 首页">
      <svg
        class="brand-mark"
        viewBox="0 0 32 32"
        width="26"
        height="26"
        aria-hidden="true"
      >
        <rect width="32" height="32" rx="7" fill="var(--accent)"></rect>
        <path
          d="M16 6c-3.6 0-6.5 2.9-6.5 6.5C9.5 17.2 16 25 16 25s6.5-7.8 6.5-12.5C22.5 8.9 19.6 6 16 6z"
          fill="#fff"></path>
        <circle cx="16" cy="12.5" r="2.6" fill="var(--accent)"></circle>
      </svg>
      <span class="brand-name">Portkey Tools</span>
    </a>

    <nav class="nav" aria-label="主导航">
      <a href="/" aria-current={isHome ? "page" : undefined}>首页</a>
      <a href="/about" aria-current={isAbout ? "page" : undefined}>关于</a>
      <a
        class="external"
        href={REPO_URL}
        target="_blank"
        rel="noopener noreferrer"
      >
        GitHub
        <svg
          class="ext-icon"
          viewBox="0 0 24 24"
          width="13"
          height="13"
          aria-hidden="true"
        >
          <path
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M14 5h5v5M19 5l-8 8M17 13v5a1 1 0 0 1-1 1H6a1 1 0 0 1-1-1V8a1 1 0 0 1 1-1h5"
          ></path>
        </svg>
      </a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    background: rgba(247, 250, 249, 0.78);
    backdrop-filter: saturate(1.4) blur(10px);
    -webkit-backdrop-filter: saturate(1.4) blur(10px);
    border-bottom: 1px solid var(--card-border);
  }
  .bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    min-height: 56px;
    padding-block: 0.5rem;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    text-decoration: none;
    color: var(--ink);
    font-weight: 700;
    letter-spacing: 0.2px;
  }
  .brand-mark {
    display: block;
    border-radius: 7px;
    transition: transform 0.25s ease;
  }
  .brand:hover .brand-mark {
    transform: rotate(-6deg) scale(1.06);
  }
  .nav {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.95rem;
  }
  .nav a {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.4rem 0.7rem;
    border-radius: 8px;
    color: var(--muted);
    text-decoration: none;
    transition:
      color 0.18s ease,
      background-color 0.18s ease;
  }
  .nav a:hover {
    color: var(--accent-ink);
    background: rgba(13, 148, 136, 0.08);
  }
  .nav a[aria-current="page"] {
    color: var(--accent-ink);
    font-weight: 600;
    background: rgba(13, 148, 136, 0.1);
  }
  .ext-icon {
    opacity: 0.7;
  }
  @media (prefers-reduced-motion: reduce) {
    .brand-mark {
      transition: none;
    }
  }
</style>
