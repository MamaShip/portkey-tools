# 依赖与构建产物
node_modules/
dist/
.astro/
coverage/

# Playwright E2E 产物（本地 / CI 临时，勿入库）
test-results/
playwright-report/
.playwright/

# 环境变量与密钥（绝不入库）
.env
.env.*

# 本地瓦片中转目录：IIIF 瓦片体量大、极少变动，存于对象存储，不进 Git
tiles/

# 底图烘焙中转目录：positron 矢量瓦片快照（scripts/bake-basemap.ts 产物），上对象存储，不进 Git
basemap-dist/

# 历史地图源扫描图：大二进制，切片后产物上对象存储，源图本地暂存不入库
*.jpg
*.jpeg
*.png
*.tif
*.tiff

# 拼幅地图（方案 B）的分幅原始导出：合并进 src/data/annotations/<mapId>.json 后即为中转输入，不入库
/chengdu-*-left.json
/chengdu-*-right.json

# 系统/编辑器杂项
.DS_Store
*.log

# IIIF 切片工具（本地下载，勿入库）
iiif-tiler.jar
